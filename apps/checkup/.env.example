# apps/checkup — variáveis de ambiente (triagem pública, :3001)

# Banco — schema `checkup` no RDS (mesmo DSN dos serviços, força SSL no client)
CHECKUP_DATABASE_URL=postgresql://user:pass@host:5432/cerebro_v3

# LLM — chave Anthropic PRÓPRIA do checkup (workspace/spend-limit separado da clínica)
ANTHROPIC_API_KEY=sk-ant-...

NEXT_PUBLIC_SITE_URL=https://checkup.cerebroamigo.com.br

# ─── Sentry (CK-1) ───
# Ideal: projeto Sentry PRÓPRIO do checkup (isolado da clínica, como a key Anthropic).
# Sem auth token o build pula upload de source maps; runtime ainda reporta via DSN.
# Postura LGPD: sem PII, sem session replay, request body/headers/query raspados.
NEXT_PUBLIC_SENTRY_DSN=https://...ingest.sentry.io/...
SENTRY_DSN=https://...ingest.sentry.io/...
SENTRY_ORG=
SENTRY_PROJECT=cerebro-amigo-checkup
SENTRY_AUTH_TOKEN=
